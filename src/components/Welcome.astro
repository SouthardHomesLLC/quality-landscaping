<div id="container" class="py-20 text-center">
  <main>
    <section id="hero" class="max-w-2xl mx-auto px-4">
      
      <svg class="absolute w-0 h-0 opacity-0 pointer-events-none" xmlns="http://www.w3.org/2000/svg">
        <filter id="white-outline">
          <feMorphology operator="dilate" radius="1" in="SourceAlpha" result="dilated" />
          <feFlood flood-color="#ffffff" style="flood-color:#ffffff;" flood-opacity="0.7" result="flooded" />
          <feComposite in="flooded" in2="dilated" operator="in" result="outline" />
          <feMerge>
            <feMergeNode in="outline" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </svg>

      <svg class="absolute w-0 h-0 opacity-0 pointer-events-none" xmlns="http://www.w3.org/2000/svg">
        <filter id="orange-outline">
          <feMorphology operator="dilate" radius="1" in="SourceAlpha" result="dilated" />
          <feFlood flood-color="#D9744B" style="flood-color:#D9744B;" flood-opacity="0.4" result="flooded" />
          <feComposite in="flooded" in2="dilated" operator="in" result="outline" />
          <feMerge>
            <feMergeNode in="outline" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </svg>

      <div>
        <div class="text-5xl font-extrabold tracking-tight mb-4 
        custom-outline text-[#D9744B]">
          <h1>
            QUALITY LANDSCAPE
          </h1>
          <h1 class="text-[#539244]">
            AND 
          </h1>
          <h1>
            LEISURE
          </h1>
        </div>
        
        <p class="text-2xl text-white mb-8 orange-custom-outline">
          Transform your outdoor space.
        </p>
      </div>
      
    </section>
  </main>
</div>

<style>
  /* The filter handles the outline, while Tailwind handles the text fill */
  .custom-outline {
    filter: url(#white-outline);
  }

  .orange-custom-outline {
    filter: url(#orange-outline);
  }
</style>