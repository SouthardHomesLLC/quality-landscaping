---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Container from "@components/container.astro";

interface Avatar {
  title: string;
  path: string;
}

interface teamProps {
  name: string;
  title: string;
  avatar: Avatar; 
}

const team: Array<teamProps> = [
  {
    name: "Ray LeClercq",
    title: "Sales Manager",
    avatar: {
      title: "Ray LeClercq Profile Picture",
      path: "https://i.postimg.cc/SNb1nW7r/Ray.jpg"
    }
  },
  {
    name: "Anthony Felker",
    title: "Web Developer",
    avatar: {
      title: "Anthony Felker Profile Picture",
      path: "https://i.postimg.cc/Z5yJc96k/Anthony.jpg"
    }
  },
];
---

<Layout title="About Quality Landscape and Leisure">
  <Container>
    <div id="container" class="py-16 md:py-24">
      <main class="space-y-20">
        
        <!-- SECTION 1: Brand & Hero Story -->
        <section id="hero" class="max-w-3xl mx-auto px-4 text-center">
          
          
          <div class="bg-white/60 backdrop-blur-sm p-6 md:p-10 rounded-2xl border border-white/50 shadow-sm text-lg text-slate-800 font-medium leading-relaxed space-y-6 text-left md:text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold text-[#2F4340] tracking-tight mb-8">
              About Us
            </h1>
            <p>
              At Quality Landscape and Leisure, we are dedicated to transforming your outdoor residential or commercial property into an inviting, high-end retreat. From custom hardscapes and lush turf installations to routine maintenance, our standard is perfection.
            </p>
            <p>
              Backed by the trusted foundation of our multi-trade Quality family of companies serving the Wabash Valley, we bring unmatched reliability, structural expertise, and creative design to every property we touch.
            </p>
          </div>
        </section>

        <!-- SECTION 2: Meet The Team Grid -->
        <section id="team" class="max-w-4xl mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-white tracking-tight mb-2">
              Meet Our Team
            </h2>
            <div class="w-16 h-1 bg-[#D9744B] mx-auto rounded-full"></div>
          </div>

          <!-- Responsive Team Layout Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 justify-center">
            {
              team.map((member) => (
                <div class="bg-[#D1D5BE]/40 backdrop-blur-sm rounded-2xl p-6 border border-white/40 shadow-sm text-center flex flex-col items-center group transition-all duration-300 hover:shadow-md hover:-translate-y-1">
                  
                  <!-- Profile Picture Frame -->
                  <div class="w-32 h-32 rounded-2xl overflow-hidden mb-4 border-2 border-white shadow-inner bg-white/50">
                    <img 
                    loading="lazy" 
                    src={member.avatar.path} 
                    alt={member.avatar.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                </div>

                  <!-- Professional Hierarchy Text -->
                  <h3 class="text-xl font-bold text-[#2F4340] mb-1">
                    {member.name}
                  </h3>
                  <p class="text-sm font-semibold text-slate-600 uppercase tracking-wider">
                    {member.title}
                  </p>
                  
                </div>
              ))
            }
          </div>
        </section>

      </main>
    </div>
  </Container>
</Layout>