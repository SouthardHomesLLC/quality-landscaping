---
import { string } from 'astro:schema';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Container from "@components/container.astro";

interface Avatar {
  title: string;
  path: string;
}

interface teamProps
{
    name: string,
    title: string,
    avatar: Avatar 
}

const team: Array<teamProps> = [
    {
        name: "Ray LeClercq",
        title: "Sales Manager",
        avatar: {
            title: "Ray LeClercq Profile Picture",
            path: "https://i.postimg.cc/W4tHsd95/ray.jpg"
        }
    }
];
---

<Layout title="About Quality Landscape and Leisure">
	<Container>
		<div id="container" class="py-20 text-center">
            <main>
                <section id="hero" class="max-w-2xl mx-auto px-4">
                    <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
                        About Us
                    </h1>
                </section>
            </main>
        </div>
	</Container>
</Layout>
